{
  "name": "figma-to-code",
  "version": "0.1.0",
  "description": "Figma URL을 넣으면 HTML/CSS/JS를 생성하고 브라우저에서 실시간 수정할 수 있는 플러그인",
  "author": {
    "name": "leejuhwan"
  },
  "skills": "./skills/",
  "mcpServers": {
    "figma": {
      "command": "npx",
      "args": ["-y", "@anthropic/figma-mcp-server"],
      "env": {
        "FIGMA_ACCESS_TOKEN": "${user_config.figma_token}"
      }
    }
  },
  "userConfig": {
    "figma_token": {
      "description": "Figma Personal Access Token (https://www.figma.com/developers/api#access-tokens)",
      "sensitive": true
    }
  }
}
